GEMINI_API_KEY=your_key_here

# --- Optional model / extraction tuning (values shown are the defaults) ---
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_TIMEOUT_MS=12000          # per-call timeout; must be >= 10000 (Gemini's minimum deadline)
# GEMINI_DEADLINE_SECONDS=12.0     # overall wall-clock budget across retries
# GEMINI_MAX_ATTEMPTS=3
# GEMINI_RETRY_BACKOFF_SECONDS=0.4

# --- Optional security hardening (sensible defaults; lock down for production) ---
# Require a bearer token on the cost-bearing endpoints (unset = open):
# APP_API_TOKEN=
# Per-IP rate limit on cost endpoints (sized for a 200-300-label batch; set REQUESTS=0 to disable):
# RATE_LIMIT_REQUESTS=120
# RATE_LIMIT_WINDOW_SECONDS=60
# Total request-body ceiling in bytes (default 25 MB):
# MAX_REQUEST_BYTES=26214400
# Set to false to disable Swagger/OpenAPI in production:
# ENABLE_DOCS=true
# Comma-separated CORS allowlist (empty = same-origin only):
# CORS_ALLOW_ORIGINS=

# --- Optional logging ---
# Level for the app logger (DEBUG / INFO / WARNING / ERROR):
# LOG_LEVEL=INFO
