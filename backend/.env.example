GEMINI_API_KEY=your_key_here

# --- Optional model / extraction tuning ---
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_TIMEOUT_MS=25000
# GEMINI_MAX_ATTEMPTS=3
# GEMINI_RETRY_BACKOFF_SECONDS=1.0

# --- Optional security hardening (sensible defaults; lock down for production) ---
# Require a bearer token on the cost-bearing endpoints (unset = open):
# APP_API_TOKEN=
# Per-IP rate limit on cost endpoints (set REQUESTS=0 to disable):
# RATE_LIMIT_REQUESTS=30
# RATE_LIMIT_WINDOW_SECONDS=60
# Total request-body ceiling in bytes (default 25 MB):
# MAX_REQUEST_BYTES=26214400
# Set to false to disable Swagger/OpenAPI in production:
# ENABLE_DOCS=true
# Comma-separated CORS allowlist (empty = same-origin only):
# CORS_ALLOW_ORIGINS=
